{
  "$schema": "https://opencode.ai/config.json",
  "share": "manual",
  "instructions": ["AGENTS.md"],
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "coverage/**",
      ".angular/**",
      ".nx/cache/**",
      ".git/**",
      "tmp/**"
    ]
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    },
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true,
      "headers": {
        "X-Goog-Api-Key": "{env:STITCH_API_KEY}"
      }
    }
  },
  "permission": {
    "bash": {
      "git commit *": "deny",
      "git push *": "deny",
      "git pull *": "deny",
      "git merge *": "deny",
      "git rebase *": "deny",
      "git reset *": "deny",
      "git clean *": "deny",
      "git restore *": "deny",
      "git checkout *": "deny",
      "git switch *": "deny",
      "git tag *": "deny",
      "git stash push *": "deny",
      "git stash pop *": "deny",
      "git stash apply *": "deny",
      "git stash drop *": "deny",
      "Remove-Item *": "deny",
      "rm *": "deny",
      "del *": "deny",
      "rmdir *": "deny",
      "npm publish *": "deny",
      "curl *": "deny",
      "wget *": "deny",
      "Invoke-WebRequest *": "deny",
      "Get-ChildItem *": "allow",
      "Get-Content *": "allow",
      "Select-String *": "allow",
      "Test-Path *": "allow",
      "ls *": "allow",
      "dir *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git rev-parse *": "allow",
      "git branch --show-current": "allow",
      "git ls-files *": "allow",
      "git check-ignore *": "allow",
      "npx nx *": "allow",
      "npx vitest *": "allow",
      "npx playwright test *": "allow",
      "npx tsc *": "allow",
      "npx eslint *": "allow",
      "npm run *": "allow",
      "npm test *": "allow",
      "npm ls *": "allow",
      "npm explain *": "allow",
      "mkdir *": "allow",
      "New-Item -ItemType Directory *": "allow",
      "Copy-Item *": "allow",
      "npm install *": "ask",
      "npm uninstall *": "ask",
      "npm update *": "ask",
      "npm ci *": "ask",
      "*": "ask"
    }
  }
}